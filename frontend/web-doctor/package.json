{
  "name": "web-doctor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:css": "node --max-old-space-size=4096 ./scripts/build-tailwind.mjs",
    "dev": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js",
    "build:ts": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -b --pretty false",
    "build:vite": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "build": "npm run build:css && npm run build:ts && npm run build:vite",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.577.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
